name = "your-proxy-name"
main = "src/index.ts"
compatibility_date = "2026-03-21"

[vars]
UPSTREAM_ORIGIN = "https://your-upstream.example.com"
TRUSTED_TENANT = "your-tenant"
TRUSTED_GATE_MAP = "{\"gate-slug\":{\"assemblyId\":\"0xYOUR_ASSEMBLY_ID\",\"tenant\":\"your-tenant\"}}"

# Set this with `wrangler secret put EF_CONTEXT_SHARED_SECRET`
# EF_CONTEXT_SHARED_SECRET = "..."

# Example when binding to a real zone:
# routes = [
#   { pattern = "hunt.example.com/*", zone_name = "example.com" }
# ]
